# Include package data and configuration files
include README.md
include LICENSE
include pyproject.toml
recursive-include src/config *.json
recursive-include src/ibexdb *.py
exclude test_with_docker.py
exclude test.sh
recursive-exclude tests *
recursive-exclude examples *
recursive-exclude test-data *
recursive-exclude docs *
prune .git
prune .github
prune __pycache__
global-exclude *.py[cod]
global-exclude __pycache__

